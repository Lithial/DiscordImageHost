# Discord webhook URL the server posts images to (required).
# Get one in Discord: Server Settings -> Integrations -> Webhooks -> Copy Webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXX/YYYYYYYY

# Absolute host directory bind-mounted read-only into the container, at the SAME
# path, so post_image can read your local image files by absolute path. Scope it
# to where the images you upload live (broaden to your home dir only if needed).
HOST_FILES_DIR=/home/youruser/coding
